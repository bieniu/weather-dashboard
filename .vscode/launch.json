{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "python": "${workspaceFolder}/backend/venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
